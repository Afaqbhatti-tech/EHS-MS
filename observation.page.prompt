─── MODEL: app/Models/Observation.php ───────────────────────

<?php
namespace App\Models;

use Illuminate\Database\Eloquent\Model;
use Illuminate\Database\Eloquent\SoftDeletes;
use Carbon\Carbon;

class Observation extends Model
{
    use SoftDeletes;

    protected $fillable = [
        'observation_id','title','description',
        'observed_date','observed_time','observed_day',
        'reported_by','reported_by_user_id',
        'team_name','supervisor_name','manager_name',
        'responsible_person','category','priority',
        'status','target_completion_date',
        'actual_closure_date','corrective_measures',
        'remarks','verified_by','before_photo',
        'after_photo','is_overdue','created_by','updated_by',
    ];

    protected $casts = [
        'observed_date'          => 'date',
        'target_completion_date' => 'date',
        'actual_closure_date'    => 'date',
        'is_overdue'             => 'boolean',
    ];

    protected static function booted(): void
    {
        static::creating(function (Observation $obs) {
            // Auto-generate observation_id
            if (empty($obs->observation_id)) {
                $year  = now()->year;
                $count = static::whereYear('created_at', $year)
                               ->withTrashed()->count() + 1;
                $obs->observation_id = 
                    'OBS-' . $year . '-' . 
                    str_pad($count, 4, '0', STR_PAD_LEFT);
            }
            // Auto-calculate day name
            if ($obs->observed_date) {
                $obs->observed_day = 
                    Carbon::parse($obs->observed_date)
                          ->format('l');
            }
        });

        static::updating(function (Observation $obs) {
            if ($obs->isDirty('observed_date') && 
                $obs->observed_date) {
                $obs->observed_day = 
                    Carbon::parse($obs->observed_date)
                          ->format('l');
            }
        });

        static::saving(function (Observation $obs) {
            // Auto-flag overdue
            if (in_array($obs->status, ['Open', 'In Progress']) 
                && $obs->target_completion_date
                && now()->gt($obs->target_completion_date)) {
                $obs->is_overdue = true;
                if ($obs->status !== 'Closed') {
                    $obs->status = 'Overdue';
                }
            }
        });
    }

    // Scopes for filtering
    public function scopeByStatus($query, $status) {
        return $query->where('status', $status);
    }

    public function scopeByTeam($query, $team) {
        return $query->where('team_name', $team);
    }

    public function scopeByDateRange($query, $from, $to) {
        return $query->whereBetween('observed_date', 
                                    [$from, $to]);
    }

    public function scopeOverdue($query) {
        return $query->where('status', 'Overdue')
                     ->orWhere(function($q) {
                         $q->whereIn('status', 
                                     ['Open','In Progress'])
                           ->whereNotNull('target_completion_date')
                           ->where('target_completion_date', '<', 
                                   now()->toDateString());
                     });
    }
}

─── CONTROLLER: app/Http/Controllers/ObservationController.php

If controller exists: add/replace methods listed below.
If not: create the file.

<?php
namespace App\Http\Controllers;

use App\Models\Observation;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Storage;
use Illuminate\Support\Facades\Auth;
use Carbon\Carbon;

class ObservationController extends Controller
{
    public function index(Request $request)
    {
        $query = Observation::query();

        // Text search
        if ($search = $request->get('search')) {
            $query->where(function($q) use ($search) {
                $q->where('title', 'like', "%$search%")
                  ->orWhere('description', 'like', "%$search%")
                  ->orWhere('observation_id', 'like', "%$search%")
                  ->orWhere('reported_by', 'like', "%$search%")
                  ->orWhere('responsible_person', 'like', "%$search%");
            });
        }

        // Status filter
        if ($status = $request->get('status')) {
            $query->where('status', $status);
        }

        // Category filter
        if ($category = $request->get('category')) {
            $query->where('category', $category);
        }

        // Priority filter
        if ($priority = $request->get('priority')) {
            $query->where('priority', $priority);
        }

        // Team filter
        if ($team = $request->get('team_name')) {
            $query->where('team_name', $team);
        }

        // Supervisor filter
        if ($supervisor = $request->get('supervisor_name')) {
            $query->where('supervisor_name', $supervisor);
        }

        // Manager filter
        if ($manager = $request->get('manager_name')) {
            $query->where('manager_name', $manager);
        }

        // Reported by filter
        if ($reporter = $request->get('reported_by')) {
            $query->where('reported_by', 'like', "%$reporter%");
        }

        // Date range
        if ($from = $request->get('date_from')) {
            $query->where('observed_date', '>=', $from);
        }
        if ($to = $request->get('date_to')) {
            $query->where('observed_date', '<=', $to);
        }

        // Period shortcuts
        if ($period = $request->get('period')) {
            match($period) {
                'today'     => $query->whereDate('observed_date', 
                               today()),
                'week'      => $query->whereBetween('observed_date',
                               [now()->startOfWeek(), 
                                now()->endOfWeek()]),
                'month'     => $query->whereMonth('observed_date',
                               now()->month)
                                     ->whereYear('observed_date',
                                     now()->year),
                'year'      => $query->whereYear('observed_date',
                               now()->year),
                default     => null,
            };
        }

        $observations = $query
            ->orderBy('created_at', 'desc')
            ->paginate($request->get('per_page', 20));

        return response()->json($observations);
    }

    public function store(Request $request)
    {
        $validated = $request->validate([
            'title'                  => 'required|string|max:500',
            'description'            => 'required|string',
            'observed_date'          => 'required|date',
            'observed_time'          => 'required',
            'reported_by'            => 'required|string|max:255',
            'team_name'              => 'nullable|string|max:255',
            'supervisor_name'        => 'nullable|string|max:255',
            'manager_name'           => 'nullable|string|max:255',
            'responsible_person'     => 'nullable|string|max:255',
            'category'               => 'nullable|string|max:100',
            'priority'               => 'nullable|in:Low,Medium,High,Critical',
            'status'                 => 'nullable|in:Open,In Progress,Closed,Overdue',
            'target_completion_date' => 'nullable|date|required_if:status,Open|required_if:status,In Progress',
            'actual_closure_date'    => 'nullable|date|required_if:status,Closed',
            'corrective_measures'    => 'nullable|string|required_if:status,Closed',
            'remarks'                => 'nullable|string',
            'verified_by'            => 'nullable|string|max:255',
            'before_photo'           => 'nullable|image|max:5120',
            'after_photo'            => 'nullable|image|max:5120',
        ]);

        $validated['created_by'] = Auth::id();
        $validated['updated_by'] = Auth::id();

        // Handle photo uploads
        if ($request->hasFile('before_photo')) {
            $validated['before_photo'] = $request
                ->file('before_photo')
                ->store('observations/photos', 'public');
        }
        if ($request->hasFile('after_photo')) {
            $validated['after_photo'] = $request
                ->file('after_photo')
                ->store('observations/photos', 'public');
        }

        $observation = Observation::create($validated);

        return response()->json([
            'message'     => 'Observation created successfully',
            'observation' => $observation,
        ], 201);
    }

    public function show(Observation $observation)
    {
        return response()->json($observation);
    }

    public function update(Request $request, 
                           Observation $observation)
    {
        $validated = $request->validate([
            'title'                  => 'sometimes|string|max:500',
            'description'            => 'sometimes|string',
            'observed_date'          => 'sometimes|date',
            'observed_time'          => 'sometimes',
            'reported_by'            => 'sometimes|string|max:255',
            'team_name'              => 'nullable|string|max:255',
            'supervisor_name'        => 'nullable|string|max:255',
            'manager_name'           => 'nullable|string|max:255',
            'responsible_person'     => 'nullable|string|max:255',
            'category'               => 'nullable|string|max:100',
            'priority'               => 'nullable|in:Low,Medium,High,Critical',
            'status'                 => 'nullable|in:Open,In Progress,Closed,Overdue',
            'target_completion_date' => 'nullable|date',
            'actual_closure_date'    => 'nullable|date',
            'corrective_measures'    => 'nullable|string',
            'remarks'                => 'nullable|string',
            'verified_by'            => 'nullable|string|max:255',
            'before_photo'           => 'nullable|image|max:5120',
            'after_photo'            => 'nullable|image|max:5120',
        ]);

        $validated['updated_by'] = Auth::id();

        if ($request->hasFile('before_photo')) {
            if ($observation->before_photo) {
                Storage::disk('public')
                       ->delete($observation->before_photo);
            }
            $validated['before_photo'] = $request
                ->file('before_photo')
                ->store('observations/photos', 'public');
        }

        if ($request->hasFile('after_photo')) {
            if ($observation->after_photo) {
                Storage::disk('public')
                       ->delete($observation->after_photo);
            }
            $validated['after_photo'] = $request
                ->file('after_photo')
                ->store('observations/photos', 'public');
        }

        $observation->update($validated);

        return response()->json([
            'message'     => 'Observation updated successfully',
            'observation' => $observation->fresh(),
        ]);
    }

    public function updateStatus(Request $request, 
                                  Observation $observation)
    {
        $request->validate([
            'status' => 'required|in:Open,In Progress,Closed,Overdue',
            'actual_closure_date'  => 'nullable|date',
            'corrective_measures'  => 'nullable|string',
        ]);

        $observation->update([
            'status'               => $request->status,
            'actual_closure_date'  => $request->actual_closure_date,
            'corrective_measures'  => $request->corrective_measures,
            'updated_by'           => Auth::id(),
        ]);

        return response()->json([
            'message'     => 'Status updated',
            'observation' => $observation->fresh(),
        ]);
    }

    public function destroy(Observation $observation)
    {
        $observation->delete();
        return response()->json(['message' => 'Deleted successfully']);
    }

    public function stats(Request $request)
    {
        $year  = $request->get('year', now()->year);
        $month = $request->get('month', now()->month);

        $base = Observation::whereYear('observed_date', $year);

        // Monthly totals for chart
        $monthly = Observation::selectRaw(
            'MONTH(observed_date) as month,
             COUNT(*) as total,
             SUM(status = "Open") as open,
             SUM(status = "In Progress") as in_progress,
             SUM(status = "Closed") as closed,
             SUM(status = "Overdue") as overdue'
        )
        ->whereYear('observed_date', $year)
        ->groupBy('month')
        ->orderBy('month')
        ->get();

        // By category
        $byCategory = Observation::selectRaw(
            'category, COUNT(*) as total'
        )
        ->whereYear('observed_date', $year)
        ->groupBy('category')
        ->get();

        // By team
        $byTeam = Observation::selectRaw(
            'team_name, COUNT(*) as total'
        )
        ->whereYear('observed_date', $year)
        ->whereNotNull('team_name')
        ->groupBy('team_name')
        ->get();

        // By safety officer
        $byOfficer = Observation::selectRaw(
            'reported_by, COUNT(*) as total'
        )
        ->whereYear('observed_date', $year)
        ->groupBy('reported_by')
        ->orderByDesc('total')
        ->limit(10)
        ->get();

        // KPI totals
        $kpis = [
            'total'       => Observation::count(),
            'open'        => Observation::where('status','Open')
                                        ->count(),
            'in_progress' => Observation::where('status',
                                         'In Progress')->count(),
            'closed'      => Observation::where('status','Closed')
                                        ->count(),
            'overdue'     => Observation::where('status','Overdue')
                                        ->count(),
        ];

        return response()->json(compact(
            'kpis','monthly','byCategory','byTeam','byOfficer'
        ));
    }

    public function export(Request $request)
    {
        // Returns CSV data for frontend download
        $query = Observation::query();
        
        if ($from = $request->get('date_from')) {
            $query->where('observed_date', '>=', $from);
        }
        if ($to = $request->get('date_to')) {
            $query->where('observed_date', '<=', $to);
        }
        if ($status = $request->get('status')) {
            $query->where('status', $status);
        }

        $observations = $query->orderBy('observed_date','desc')
                              ->get();

        $headers = [
            'Content-Type'        => 'text/csv',
            'Content-Disposition' => 
                'attachment; filename="observations_' . 
                now()->format('Y-m-d') . '.csv"',
        ];

        $callback = function() use ($observations) {
            $handle = fopen('php://output', 'w');
            fputcsv($handle, [
                'Observation ID','Date','Day','Time','Title',
                'Description','Reported By','Team','Supervisor',
                'Manager','Responsible Person','Category',
                'Priority','Status','Target Date','Closed Date',
                'Corrective Measures','Remarks','Verified By',
                'Created At',
            ]);
            foreach ($observations as $obs) {
                fputcsv($handle, [
                    $obs->observation_id,
                    $obs->observed_date?->format('Y-m-d'),
                    $obs->observed_day,
                    $obs->observed_time,
                    $obs->title,
                    $obs->description,
                    $obs->reported_by,
                    $obs->team_name,
                    $obs->supervisor_name,
                    $obs->manager_name,
                    $obs->responsible_person,
                    $obs->category,
                    $obs->priority,
                    $obs->status,
                    $obs->target_completion_date?->format('Y-m-d'),
                    $obs->actual_closure_date?->format('Y-m-d'),
                    $obs->corrective_measures,
                    $obs->remarks,
                    $obs->verified_by,
                    $obs->created_at?->format('Y-m-d H:i'),
                ]);
            }
            fclose($handle);
        };

        return response()->stream($callback, 200, $headers);
    }
}

