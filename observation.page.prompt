import React from 'react';

const STATUS_STYLES = {
    'Open': {
        background: 'var(--status-open)',
        color: 'var(--status-open-text)',
        border: '1px solid var(--status-open-border)',
    },
    'In Progress': {
        background: 'var(--status-inprogress)',
        color: 'var(--status-inprogress-text)',
        border: '1px solid var(--status-inprogress-border)',
    },
    'Closed': {
        background: 'var(--status-closed)',
        color: 'var(--status-closed-text)',
        border: '1px solid var(--status-closed-border)',
    },
    'Overdue': {
        background: 'var(--status-overdue)',
        color: 'var(--status-overdue-text)',
        border: '1px solid var(--status-overdue-border)',
    },
};

const PRIORITY_STYLES = {
    'Low':      { background: '#F0F9FF', color: '#0369A1',
                  border: '1px solid #BAE6FD' },
    'Medium':   { background: '#FFFBEB', color: '#92400E',
                  border: '1px solid #FCD34D' },
    'High':     { background: '#FEF3C7', color: '#92400E',
                  border: '1px solid #FCD34D' },
    'Critical': { background: '#FEE2E2', color: '#991B1B',
                  border: '1px solid #FCA5A5' },
};

export function StatusBadge({ status }) {
    const style = STATUS_STYLES[status] || {};
    return (
        <span style={{
            ...style,
            padding: '3px 9px',
            borderRadius: 'var(--radius-full)',
            fontSize: 'var(--text-xs)',
            fontWeight: 600,
            whiteSpace: 'nowrap',
            display: 'inline-block',
            transition: 'all var(--transition-base)',
        }}>
            {status}
        </span>
    );
}

export function PriorityBadge({ priority }) {
    const style = PRIORITY_STYLES[priority] || {};
    return (
        <span style={{
            ...style,
            padding: '3px 9px',
            borderRadius: 'var(--radius-full)',
            fontSize: 'var(--text-xs)',
            fontWeight: 600,
            whiteSpace: 'nowrap',
            display: 'inline-block',
        }}>
            {priority}
        </span>
    );
}

