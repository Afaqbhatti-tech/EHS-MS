─── CUSTOM HOOK: useObservations.js ─────────────────────────

import { useState, useEffect, useCallback } from 'react';
import axios from 'axios';

const API = '/api/observations';

export function useObservations() {
    const [observations, setObservations] = useState([]);
    const [stats, setStats]               = useState(null);
    const [loading, setLoading]           = useState(false);
    const [statsLoading, setStatsLoading] = useState(false);
    const [error, setError]               = useState(null);
    const [pagination, setPagination]     = useState({});

    const [filters, setFilters] = useState({
        search:          '',
        status:          '',
        category:        '',
        priority:        '',
        team_name:       '',
        supervisor_name: '',
        manager_name:    '',
        reported_by:     '',
        period:          '',
        date_from:       '',
        date_to:         '',
        per_page:        20,
        page:            1,
    });

    const fetchObservations = useCallback(async (params) => {
        setLoading(true);
        setError(null);
        try {
            const cleanParams = Object.fromEntries(
                Object.entries(params).filter(([,v]) => v !== '')
            );
            const { data } = await axios.get(API, { 
                params: cleanParams 
            });
            setObservations(data.data || data);
            setPagination({
                currentPage:  data.current_page,
                lastPage:     data.last_page,
                total:        data.total,
                perPage:      data.per_page,
            });
        } catch (err) {
            setError(err.response?.data?.message || 
                     'Failed to load observations');
        } finally {
            setLoading(false);
        }
    }, []);

    const fetchStats = useCallback(async () => {
        setStatsLoading(true);
        try {
            const { data } = await axios.get(`${API}/stats`);
            setStats(data);
        } catch (err) {
            console.error('Stats fetch error:', err);
        } finally {
            setStatsLoading(false);
        }
    }, []);

    useEffect(() => {
        fetchObservations(filters);
    }, [filters, fetchObservations]);

    useEffect(() => {
        fetchStats();
    }, [fetchStats]);

    const createObservation = async (formData) => {
        const { data } = await axios.post(API, formData, {
            headers: { 'Content-Type': 'multipart/form-data' },
        });
        await fetchObservations(filters);
        await fetchStats();
        return data;
    };

    const updateObservation = async (id, formData) => {
        formData.append('_method', 'PUT');
        const { data } = await axios.post(`${API}/${id}`, 
            formData, {
            headers: { 'Content-Type': 'multipart/form-data' },
        });
        await fetchObservations(filters);
        await fetchStats();
        return data;
    };

    const updateStatus = async (id, statusData) => {
        const { data } = await axios.patch(
            `${API}/${id}/status`, statusData
        );
        setObservations(prev => prev.map(obs => 
            obs.id === id ? data.observation : obs
        ));
        await fetchStats();
        return data;
    };

    const deleteObservation = async (id) => {
        await axios.delete(`${API}/${id}`);
        await fetchObservations(filters);
        await fetchStats();
    };

    const exportCSV = async (exportFilters = {}) => {
        const params = new URLSearchParams(
            Object.fromEntries(
                Object.entries({...filters, ...exportFilters})
                      .filter(([,v]) => v !== '')
            )
        );
        window.location.href = 
            `${API}/export?${params.toString()}`;
    };

    return {
        observations, stats, loading, statsLoading,
        error, pagination, filters, setFilters,
        createObservation, updateObservation,
        updateStatus, deleteObservation, exportCSV,
        refresh: () => {
            fetchObservations(filters);
            fetchStats();
        },
    };
}

─── KPI CARDS: ObservationKPICards.jsx ──────────────────────

import React from 'react';

const KPI_CONFIG = [
    { 
        key: 'total', 
        label: 'Total Observations', 
        icon: '📋', 
        color: 'var(--green-600)',
        bg: 'var(--green-50)',
        border: 'var(--green-200)',
    },
    { 
        key: 'open', 
        label: 'Open', 
        icon: '🔵',
        color: 'var(--status-open-text)',
        bg: 'var(--status-open)',
        border: 'var(--status-open-border)',
    },
    { 
        key: 'in_progress', 
        label: 'In Progress', 
        icon: '🟡',
        color: 'var(--status-inprogress-text)',
        bg: 'var(--status-inprogress)',
        border: 'var(--status-inprogress-border)',
    },
    { 
        key: 'closed', 
        label: 'Closed', 
        icon: '🟢',
        color: 'var(--status-closed-text)',
        bg: 'var(--status-closed)',
        border: 'var(--status-closed-border)',
    },
    { 
        key: 'overdue', 
        label: 'Overdue', 
        icon: '🔴',
        color: 'var(--status-overdue-text)',
        bg: 'var(--status-overdue)',
        border: 'var(--status-overdue-border)',
    },
];

export function ObservationKPICards({ kpis, loading }) {
    if (loading) {
        return (
            <div className="kpi-grid">
                {KPI_CONFIG.map((_, i) => (
                    <div key={i} className="kpi-card kpi-skeleton">
                        <div className="skeleton" 
                             style={{height:20,width:'40%',
                                     marginBottom:12}} />
                        <div className="skeleton" 
                             style={{height:36,width:'60%'}} />
                    </div>
                ))}
            </div>
        );
    }

    return (
        <div className="kpi-grid">
            {KPI_CONFIG.map((cfg, i) => (
                <div
                    key={cfg.key}
                    className="kpi-card animate-fadeInUp"
                    style={{
                        backgroundColor: cfg.bg,
                        borderColor: cfg.border,
                        animationDelay: `${i * 60}ms`,
                    }}
                >
                    <div className="kpi-card__header">
                        <span className="kpi-card__icon">
                            {cfg.icon}
                        </span>
                        <span className="kpi-card__label">
                            {cfg.label}
                        </span>
                    </div>
                    <div 
                        className="kpi-card__value"
                        style={{ color: cfg.color }}
                    >
                        {kpis?.[cfg.key] ?? '—'}
                    </div>
                </div>
            ))}
        </div>
    );
}

